{
  "version": 2,
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/api/index.rs"
    }
  ],
  "images": {
    "sizes": [256, 384, 640, 750, 828, 1080, 1200, 1920, 2048, 3840],
    "domains": ["protectionvalley.com", "www.protectionvalley.com"],
    "minimumCacheTTL": 60,
    "formats": ["image/avif", "image/webp"]
  }
}
